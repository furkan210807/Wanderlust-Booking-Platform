<% layout("/layouts/boilerplate") %>

<body>

    <h3>All Listings</h3>

    <!-- 🔥 CREATE BUTTON -->
    <!-- <a href="/listings/new">
        <button>Create New Listing</button>
    </a> -->
    <div class="row row-cols-lg-5 row-cols-md-3 row-cols-sm-3">
        
     <% for(let listing of allListings){ %>
    <a href="/listings/<%= listing._id %>" class="listing-link">
    <div class="card col listing-card" style="width: 15rem;">
  <img src="<%=listing.image.url%>" class="card-img-top" alt="listing_image" style="height:13rem"/>
   <div class="card-img-overlay">a</div>
  <div class="card-body">
    <p class="card-text">
        <b><%=listing.title %> <br></b>
       <!-- &#8377;  listing.price.toLocaleString("en-IN") %> /night <br> -->
       &#8377; <%= listing.price ? listing.price.toLocaleString("en-IN") : "N/A" %> /night <br>
    </p>
    </div>
    </div>
    </a>

<% } %>
</div>


   

</body>
